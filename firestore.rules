rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Hard-whitelisted owner email — always super admin
    function isOwnerEmail() {
      return isSignedIn() &&
        request.auth.token.email == "shawndavidsobremontedomingo@gmail.com";
    }

    // Any signed-in user with an email (non-anonymous Google login).
    // This intentionally uses != null check on email — works immediately
    // after signInWithPopup without requiring a token refresh round-trip.
    function isAuthenticatedUser() {
      return isSignedIn() && request.auth.token.email != null;
    }

    // NEU institutional email — covers all appointed staff (@neu.edu.ph)
    // plus the hardcoded owner gmail
    function isNEUEmail() {
      return isAuthenticatedUser() &&
        (request.auth.token.email.matches('.*@neu\\.edu\\.ph') ||
         request.auth.token.email == "shawndavidsobremontedomingo@gmail.com");
    }

    // /users — unified collection
    // Read: any signed-in user (including right after Google popup — isSignedIn()
    // is satisfied immediately, avoiding token-propagation race conditions).
    // Write guards remain strict.
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwnerEmail() ||
                       isNEUEmail() ||
                       (isAuthenticatedUser() && resource.data.email == request.auth.token.email);
      allow delete: if isNEUEmail() || isOwnerEmail() || isAuthenticatedUser();
    }

    match /departments/{deptID} {
      allow read: if true;
      allow write: if isNEUEmail() || isOwnerEmail();
    }

    match /library_logs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAuthenticatedUser();
      allow delete: if isNEUEmail() || isOwnerEmail();
    }

    match /programs/{programId} {
      allow read: if true;
      allow write: if isNEUEmail() || isOwnerEmail();
    }

    match /notifications/{notifId} {
      allow read:   if isSignedIn();
      allow create: if isAuthenticatedUser();
      allow update: if isSignedIn();
      allow delete: if isAuthenticatedUser();
    }

    // /visit_purposes — public read so anonymous kiosk can fetch
    match /visit_purposes/{purposeId} {
      allow read:  if true;
      allow write: if isNEUEmail() || isOwnerEmail();
    }

    // /audit_logs — append-only, immutable
    match /audit_logs/{logId} {
      allow read:   if isNEUEmail() || isOwnerEmail();
      allow create: if isAuthenticatedUser();
      allow update: if false;
      allow delete: if isNEUEmail() || isOwnerEmail();
    }

    // /credential_requests
    match /credential_requests/{reqId} {
      allow read:   if isAuthenticatedUser();
      allow create: if isSignedIn();
      allow update: if isNEUEmail() || isOwnerEmail();
      allow delete: if isOwnerEmail();
    }

    // /blocked_attempts — written by kiosk when a restricted user taps in.
    // Admins/staff can read; any signed-in user (including kiosk session) can create.
    // Updates restricted to NEU/admin accounts only — needed for studentId cascade
    // when an ID change request is approved. Records are otherwise append-only.
    match /blocked_attempts/{attemptId} {
      allow read:   if isNEUEmail() || isOwnerEmail();
      allow create: if isSignedIn();
      allow update: if isNEUEmail() || isOwnerEmail();
      allow delete: if isOwnerEmail();
    }

  }
}
